# .env.example - Environment configuration template for MVDP System
# Copy this to .env and fill in your actual values

# Database Configuration
# MS SQL Server connection details
DATABASE_DRIVER=ODBC Driver 17 for SQL Server
DATABASE_SERVER=localhost
DATABASE_NAME=MVDP_DB
DATABASE_USER=sa
DATABASE_PASSWORD=YourPassword123

# CORS Configuration
# Allowed origins for frontend requests
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# API Configuration
API_TITLE=MVDP Concrete Reconciliation System
API_VERSION=1.0.0

# Business Rules
ACE_LIMIT_PERCENT=1.0

# Additional Notes:
# - For production, use strong database passwords
# - Consider using environment-specific configurations
# - Update CORS_ORIGINS based on frontend deployment URL
# - ACE_LIMIT_PERCENT: Maximum allowed wastage percentage (1%)
